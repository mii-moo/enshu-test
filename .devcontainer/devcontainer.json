{
  "name": "ERP Practice",
  "build": { "dockerfile": "../Dockerfile" },
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "notify" 
    }
  },
  // 環境構築時にライブラリをインストールする命令を追加
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt",
  
  // 起動時にアプリを立ち上げる
  "postStartCommand": "streamlit run main.py" 
}